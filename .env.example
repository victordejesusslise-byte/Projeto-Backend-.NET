# ============================================================
# Configuração das conexões com SQL Server
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA faça commit do .env com dados reais!
# ============================================================

# Execução local no Windows com autenticação integrada.
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS03;Database=usuarios_db;Trusted_Connection=True;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# Execução da API pelo Docker conectando ao SQLEXPRESS03 do host.
# O container Linux não usa a autenticação integrada do Windows. No SQL Server:
# 1. habilite TCP/IP e configure uma porta TCP fixa, por exemplo 1433;
# 2. habilite autenticação do SQL Server (modo misto);
# 3. crie um login próprio para a API e permita a porta no firewall.
# Troque os valores abaixo no seu arquivo .env; não versione a senha real.
SQLSERVER_DOCKER_CONNECTION=Server=host.docker.internal,1433;Database=usuarios_db;User Id=usuarios_api;Password=TROQUE_POR_UMA_SENHA_FORTE;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# Ambiente
ASPNETCORE_ENVIRONMENT=Development

# Hosts aceitos pela API. Em produção, troque pelo domínio real.
ALLOWED_HOSTS=localhost;127.0.0.1
